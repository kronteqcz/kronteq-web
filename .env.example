# SMTP konfigurace — kontaktní formulář
# Zkopíruj do .env a doplň hodnoty

# SMTP server (např. smtp.seznam.cz, mail.kronteq.com, smtp.gmail.com)
SMTP_HOST=smtp.example.com

# Port: 587 = STARTTLS (doporučeno), 465 = SSL, 25 = bez šifrování
SMTP_PORT=587

# true pokud port=465 (přímé SSL), false pro STARTTLS (port 587)
SMTP_SECURE=false

# Přihlašovací údaje k SMTP
SMTP_USER=info@kronteq.com
SMTP_PASS=tajne-heslo

# Odesílatel (zobrazí se v poli "From" v emailu)
SMTP_FROM="Kronteq web <info@kronteq.com>"

# Příjemce poptávek (kam chodit emaily z formuláře)
SMTP_TO=ondrackova@kronteq.com

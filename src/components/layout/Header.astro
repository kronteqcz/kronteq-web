---
import type { Lang } from '../../i18n/strings';
import { getLang } from '../../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'cs' } = Astro.props;
const t = getLang(lang);

const navItems = [
  { label: t.navSolutions, href: lang === 'en' ? '/en/solutions/' : '/reseni/' },
  { label: t.navIndustries, href: lang === 'en' ? '/en/industries/' : '/odvtvi/' },
  { label: t.navAbout, href: lang === 'en' ? '/en/about/' : '/o-nas/' },
  { label: t.navContact, href: lang === 'en' ? '/en/contact/' : '/kontakt/' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/' || href === '/en/') return currentPath === href;
  return currentPath.startsWith(href);
}
const homeHref = lang === 'en' ? '/en/' : '/';
---

<header class="site-header" id="site-header">
  <div class="header-inner container">
    <!-- Logo -->
    <a href={homeHref} class="logo" aria-label="Kronteq — zpět na úvod">
      <span class="logo-kq" aria-hidden="true">KQ</span>
      <span class="logo-name">KRONTEQ</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="nav-desktop" aria-label={lang === 'en' ? 'Main navigation' : 'Hlavní navigace'}>
      <ul role="list">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class={isActive(item.href) ? 'nav-link active' : 'nav-link'}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <!-- Lang switcher -->
      <a href={t.switchLangHref} class="lang-switch" aria-label={`Switch to ${t.switchLang}`}>
        {t.switchLang}
      </a>

      <!-- CTA -->
      <a href={lang === 'en' ? '/en/contact/' : '/kontakt/'} class="header-cta">
        {t.navContactCta}
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      class="menu-toggle"
      id="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label={lang === 'en' ? 'Open navigation' : 'Otevřít navigaci'}
    >
      <span class="menu-bar" aria-hidden="true"></span>
      <span class="menu-bar" aria-hidden="true"></span>
      <span class="menu-bar" aria-hidden="true"></span>
    </button>
  </div>

  <!-- Mobile Nav -->
  <nav class="nav-mobile" id="mobile-nav" aria-hidden="true">
    <ul role="list">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class={isActive(item.href) ? 'nav-link active' : 'nav-link'}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="mobile-actions">
        <a href={t.switchLangHref} class="lang-switch">{t.switchLang}</a>
        <a href={lang === 'en' ? '/en/contact/' : '/kontakt/'} class="btn-primary" style="font-size:0.875rem;padding:0.5rem 1.25rem;">
          {t.navContactCta}
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const toggle = document.getElementById('menu-toggle')!;
  const mobileNav = document.getElementById('mobile-nav')!;

  let lastY = 0;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    header.classList.toggle('scrolled', y > 60);
    if (y > 200 && y > lastY) header.classList.add('hidden');
    else header.classList.remove('hidden');
    lastY = y;
  }, { passive: true });

  toggle.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    mobileNav.setAttribute('aria-hidden', String(isOpen));
    toggle.classList.toggle('open', !isOpen);
    mobileNav.classList.toggle('open', !isOpen);
    document.body.classList.toggle('nav-open', !isOpen);
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg-nav);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration) var(--ease), transform 0.4s var(--ease);
  }
  .site-header.scrolled { border-bottom-color: rgba(255,255,255,0.08); }
  .site-header.hidden { transform: translateY(-100%); }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 72px;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-kq {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: var(--brand);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 0.8125rem;
    letter-spacing: 0.05em;
    border-radius: 10px;
    flex-shrink: 0;
    transition: box-shadow var(--duration) var(--ease);
  }
  .logo:hover .logo-kq {
    box-shadow: 0 0 20px rgba(124, 58, 237, 0.4);
  }
  .logo-name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.12em;
    color: #fff;
  }

  /* Desktop nav */
  .nav-desktop { flex: 1; }
  .nav-desktop ul {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }
  .nav-link {
    position: relative;
    display: inline-block;
    padding: 0.4rem 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--duration) var(--ease), background var(--duration) var(--ease);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    background: var(--accent-light);
    border-radius: 1px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease);
  }
  .nav-link:hover { color: #fff; background: rgba(255,255,255,0.06); }
  .nav-link.active { color: var(--accent-light); }
  .nav-link.active::after { transform: scaleX(1); }

  /* Header actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* Language switcher */
  .lang-switch {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255,255,255,0.15);
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }
  .lang-switch:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.4);
  }

  /* CTA */
  .header-cta {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    background: var(--accent);
    border-radius: 100px;
    padding: 0.45rem 1.1rem;
    transition: background var(--duration) var(--ease);
  }
  .header-cta:hover { background: var(--accent-hover); color: #fff; }

  /* Mobile toggle */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
  }
  .menu-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 1px;
    transition: transform 0.3s var(--ease), opacity 0.3s var(--ease);
  }
  .menu-toggle.open .menu-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle.open .menu-bar:nth-child(2) { opacity: 0; }
  .menu-toggle.open .menu-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile nav */
  .nav-mobile {
    display: none;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .nav-mobile ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .nav-mobile .nav-link {
    display: block;
    padding: 0.6rem 0.75rem;
    font-size: 1rem;
  }
  .mobile-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.75rem 0;
    margin-top: 0.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  @media (max-width: 900px) {
    .nav-desktop { display: none; }
    .header-actions { display: none; }
    .menu-toggle { display: flex; }
    .nav-mobile.open { display: block; }
  }

  :global(body.nav-open) { overflow: hidden; }
</style>

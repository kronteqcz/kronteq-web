---
// WeldVsGlue.astro
// Side-by-side comparison: welding limitations vs adhesive advantages
interface Props {
  width?: number;
  height?: number;
  class?: string;
}
const { width = 560, height = 260, class: className = '' } = Astro.props;

const weldPoints = [
  'Pouze stejné materiály',
  'Tepelné deformace',
  'HAZ — zóna tepelného ovlivnění',
  'Bodové napětí v místě sváru',
  'Omezená geometrie',
];
const gluePoints = [
  'Kov + plast + kompozit + sklo',
  'Bez tepelného ovlivnění',
  'Rovnoměrná distribuce napětí',
  'Tlumení vibrací a NVH',
  'Komplexní geometrie',
];
---

<svg
  viewBox={`0 0 ${width} ${height}`}
  width={width}
  height={height}
  class={className}
  aria-label="Srovnání svařování a lepení"
  role="img"
  xmlns="http://www.w3.org/2000/svg"
>
  <rect width={width} height={height} fill="#1a0f35" rx="12"/>

  <!-- Panel headers -->
  <rect x="20" y="16" width="240" height="32" rx="6" fill="rgba(248,113,113,0.12)" stroke="rgba(248,113,113,0.3)" stroke-width="1"/>
  <text x="140" y="37" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="#f87171">SVAŘOVÁNÍ</text>

  <rect x="300" y="16" width="240" height="32" rx="6" fill="rgba(74,222,128,0.12)" stroke="rgba(74,222,128,0.3)" stroke-width="1"/>
  <text x="420" y="37" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="#4ade80">LEPENÍ</text>

  <!-- VS badge -->
  <circle cx={width/2} cy="32" r="16" fill="#1a0f35" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
  <text x={width/2} y="37" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="rgba(255,255,255,0.5)">VS</text>

  <!-- Weld items -->
  {weldPoints.map((pt, i) => {
    const y = 72 + i * 36;
    return (
      <g>
        <rect x="20" y={y - 16} width="240" height="30" rx="4" fill="rgba(248,113,113,0.06)"/>
        <circle cx="38" cy={y} r="8" fill="rgba(248,113,113,0.15)" stroke="rgba(248,113,113,0.4)" stroke-width="1"/>
        <text x="38" y={y + 4} text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#f87171">✕</text>
        <text x="54" y={y + 4} font-family="Inter, sans-serif" font-size="11" fill="rgba(255,255,255,0.55)">{pt}</text>
      </g>
    );
  })}

  <!-- Glue items -->
  {gluePoints.map((pt, i) => {
    const y = 72 + i * 36;
    return (
      <g>
        <rect x="300" y={y - 16} width="240" height="30" rx="4" fill="rgba(74,222,128,0.06)"/>
        <circle cx="318" cy={y} r="8" fill="rgba(74,222,128,0.15)" stroke="rgba(74,222,128,0.4)" stroke-width="1"/>
        <text x="318" y={y + 4} text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#4ade80">✓</text>
        <text x="334" y={y + 4} font-family="Inter, sans-serif" font-size="11" fill="rgba(255,255,255,0.55)">{pt}</text>
      </g>
    );
  })}

  <!-- Bottom note -->
  <text x={width/2} y={height - 10} text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.25)">Hybridní spoj (weld-bonding) kombinuje výhody obou technologií</text>
</svg>

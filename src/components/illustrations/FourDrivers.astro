---
// FourDrivers.astro
// Four drivers of adhesive bonding adoption: weight, multi-material, sealing, NVH
interface Props {
  width?: number;
  height?: number;
  class?: string;
}
const { width = 480, height = 260, class: className = '' } = Astro.props;

const drivers = [
  {
    icon: '⬇',
    title: 'Odlehčení',
    desc: 'Žádné šrouby, nýty ani zálitkové matice — čistá hmotnost spoje.',
    color: '#4ade80',
    x: 120,
    y: 80,
  },
  {
    icon: '⊕',
    title: 'Multi-material',
    desc: 'Spájí kov, plast, sklo a kompozit bez galvanické koroze.',
    color: '#fb923c',
    x: 360,
    y: 80,
  },
  {
    icon: '◈',
    title: 'Těsnění',
    desc: 'Spoj je zároveň bariéra — voda, prach, vzduch nevnikají.',
    color: '#60a5fa',
    x: 120,
    y: 186,
  },
  {
    icon: '≈',
    title: 'NVH tlumení',
    desc: 'Elastická vrstva absorbuje vibrace a hluk.',
    color: '#c084fc',
    x: 360,
    y: 186,
  },
];
---

<svg
  viewBox={`0 0 ${width} ${height}`}
  width={width}
  height={height}
  class={className}
  aria-label="Čtyři hlavní důvody pro konstrukční lepení"
  role="img"
  xmlns="http://www.w3.org/2000/svg"
>
  <rect width={width} height={height} fill="#1a0f35" rx="12"/>

  <!-- Title -->
  <text x={width/2} y="20" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="rgba(255,255,255,0.35)" letter-spacing="0.06em">PROČ PRŮMYSL VOLÍ LEPENÍ</text>

  <!-- Center logo / intersection -->
  <circle cx={width/2} cy={height/2} r="28" fill="rgba(45,27,85,0.8)" stroke="rgba(124,58,237,0.4)" stroke-width="1.5"/>
  <text x={width/2} y={height/2 + 5} text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="rgba(124,58,237,0.9)">LEPENÍ</text>

  {drivers.map(d => {
    // Connector line from card center to center circle
    const cx = width / 2;
    const cy = height / 2;
    const dx = d.x - cx;
    const dy = d.y - cy;
    const len = Math.sqrt(dx*dx + dy*dy);
    const nx = dx / len;
    const ny = dy / len;
    const x1 = cx + nx * 30;
    const y1 = cy + ny * 30;
    const x2 = d.x - nx * 60;
    const y2 = d.y - ny * 28;
    return (
      <g>
        <line x1={x1} y1={y1} x2={x2} y2={y2} stroke={`${d.color}55`} stroke-width="1" stroke-dasharray="4,3"/>
        <rect x={d.x - 100} y={d.y - 50} width="200" height="100" rx="10" fill="rgba(45,27,85,0.7)" stroke={`${d.color}44`} stroke-width="1.5"/>
        <text x={d.x} y={d.y - 22} text-anchor="middle" font-family="Inter, sans-serif" font-size="20" fill={d.color}>{d.icon}</text>
        <text x={d.x} y={d.y + 2} text-anchor="middle" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="#fff">{d.title}</text>
        <foreignObject x={d.x - 86} y={d.y + 8} width="172" height="38">
          <div xmlns="http://www.w3.org/1999/xhtml" style="font-family: Inter, sans-serif; font-size: 10px; color: rgba(255,255,255,0.45); text-align: center; line-height: 1.4;">
            {d.desc}
          </div>
        </foreignObject>
      </g>
    );
  })}
</svg>

---
// AdhesiveSpectrum.astro
// Scatter-style chart: strength (Y) vs elasticity (X) for 5 adhesive types
interface Props {
  width?: number;
  height?: number;
  class?: string;
}
const { width = 520, height = 300, class: className = '' } = Astro.props;

const types = [
  { label: 'Epoxid', x: 68, y: 220, color: '#f87171', radius: 18 },
  { label: 'MMA', x: 200, y: 160, color: '#fb923c', radius: 16 },
  { label: 'CA', x: 52, y: 180, color: '#facc15', radius: 13 },
  { label: 'PUR', x: 330, y: 100, color: '#4ade80', radius: 16 },
  { label: 'Silikon', x: 400, y: 55, color: '#7c3aed', radius: 14 },
];
---

<svg
  viewBox={`0 0 ${width} ${height}`}
  width={width}
  height={height}
  class={className}
  aria-label="Spektrum průmyslových lepidel: pevnost versus pružnost"
  role="img"
  xmlns="http://www.w3.org/2000/svg"
>
  <rect width={width} height={height} fill="#1a0f35" rx="12"/>

  <!-- Grid lines -->
  {[0,1,2,3,4].map((i) => {
    const y = 36 + i * 48;
    return (
      <line x1="60" y1={y} x2={width - 30} y2={y} stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
    );
  })}
  {[0,1,2,3,4].map((i) => {
    const x = 60 + i * 96;
    return (
      <line x1={x} y1="20" x2={x} y2={height - 44} stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
    );
  })}

  <!-- Axes -->
  <line x1="60" y1="20" x2="60" y2={height - 44} stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/>
  <line x1="60" y1={height - 44} x2={width - 20} y2={height - 44} stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/>

  <!-- Axis labels -->
  <text x="32" y={height / 2} text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="rgba(255,255,255,0.45)" transform={`rotate(-90, 18, ${height/2})`}>Pevnost (MPa)</text>
  <text x={width / 2} y={height - 6} text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="rgba(255,255,255,0.45)">Pružnost / Tažnost (%)</text>

  <!-- Y axis ticks -->
  <text x="54" y="40" text-anchor="end" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">90</text>
  <text x="54" y="88" text-anchor="end" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">70</text>
  <text x="54" y="136" text-anchor="end" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">40</text>
  <text x="54" y="184" text-anchor="end" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">20</text>
  <text x="54" y="232" text-anchor="end" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">5</text>

  <!-- X axis ticks -->
  <text x="60" y={height - 28} text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">0</text>
  <text x="156" y={height - 28} text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">100</text>
  <text x="252" y={height - 28} text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">300</text>
  <text x="348" y={height - 28} text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">500</text>
  <text x="444" y={height - 28} text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">800</text>

  <!-- Trend arrow: inverse correlation -->
  <path d="M 80 46 Q 260 130 440 228" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" stroke-dasharray="6,4" fill="none"/>

  <!-- Data points -->
  {types.map(t => (
    <g>
      <circle cx={t.x + 60} cy={t.y} r={t.radius} fill={t.color} opacity="0.85"/>
      <circle cx={t.x + 60} cy={t.y} r={t.radius + 4} fill="none" stroke={t.color} stroke-width="1" opacity="0.3"/>
      <text
        x={t.x + 60}
        y={t.y - t.radius - 6}
        text-anchor="middle"
        font-family="Inter, sans-serif"
        font-size="11"
        font-weight="600"
        fill={t.color}
      >{t.label}</text>
    </g>
  ))}

  <!-- Title -->
  <text x={width / 2} y="14" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="rgba(255,255,255,0.4)" letter-spacing="0.05em">PEVNOST × PRUŽNOST</text>
</svg>

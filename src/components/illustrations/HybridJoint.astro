---
// HybridJoint.astro
// Weld-bonding: adhesive layer + spot welds combination
interface Props {
  width?: number;
  height?: number;
  class?: string;
}
const { width = 500, height = 240, class: className = '' } = Astro.props;

const welds = [80, 180, 280, 380, 440];
---

<svg
  viewBox={`0 0 ${width} ${height}`}
  width={width}
  height={height}
  class={className}
  aria-label="Hybridní spoj: kombinace lepení a bodového sváru"
  role="img"
  xmlns="http://www.w3.org/2000/svg"
>
  <rect width={width} height={height} fill="#1a0f35" rx="12"/>

  <!-- Title -->
  <text x={width/2} y="22" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="rgba(255,255,255,0.4)" letter-spacing="0.06em">WELD-BONDING</text>

  <!-- Top substrate -->
  <rect x="30" y="34" width={width - 60} height="40" rx="4" fill="#2d1b55" stroke="rgba(124,58,237,0.35)" stroke-width="1.5"/>
  <text x={width/2} y="59" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="rgba(255,255,255,0.5)">ocelový plech / hliník</text>

  <!-- Adhesive layer -->
  <rect x="30" y="74" width={width - 60} height="32" rx="0" fill="rgba(124,58,237,0.2)" stroke="rgba(124,58,237,0.4)" stroke-width="1"/>
  <text x={width/2} y="94" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="rgba(124,58,237,0.85)">epoxidové lepidlo (crash-durable)</text>

  <!-- Bottom substrate -->
  <rect x="30" y="106" width={width - 60} height="40" rx="4" fill="#2d1b55" stroke="rgba(124,58,237,0.35)" stroke-width="1.5"/>
  <text x={width/2} y="131" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="rgba(255,255,255,0.5)">ocelový plech / hliník</text>

  <!-- Spot welds (overlapping both plates and adhesive) -->
  {welds.map(x => (
    <g>
      <ellipse cx={x} cy="90" rx="12" ry="32" fill="rgba(251,191,36,0.15)" stroke="rgba(251,191,36,0.5)" stroke-width="1.5"/>
      <ellipse cx={x} cy="90" rx="6" ry="8" fill="rgba(251,191,36,0.6)"/>
      <!-- Spark lines -->
      <line x1={x-10} y1="68" x2={x-14} y2="62" stroke="rgba(251,191,36,0.6)" stroke-width="1"/>
      <line x1={x} y1="64" x2={x} y2="58" stroke="rgba(251,191,36,0.6)" stroke-width="1"/>
      <line x1={x+10} y1="68" x2={x+14} y2="62" stroke="rgba(251,191,36,0.6)" stroke-width="1"/>
    </g>
  ))}

  <!-- Force arrows showing load transfer -->
  <line x1="60" y1="168" x2="60" y2="186" stroke="#4ade80" stroke-width="2"/>
  <polygon points="56,182 64,182 60,190" fill="#4ade80"/>
  <text x="60" y="204" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" fill="rgba(255,255,255,0.4)">statické</text>
  <text x="60" y="215" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" fill="rgba(255,255,255,0.4)">zatížení</text>

  <line x1="250" y1="168" x2="250" y2="186" stroke="#fb923c" stroke-width="2"/>
  <polygon points="246,182 254,182 250,190" fill="#fb923c"/>
  <text x="250" y="204" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" fill="rgba(255,255,255,0.4)">rázové</text>
  <text x="250" y="215" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" fill="rgba(255,255,255,0.4)">zatížení</text>

  <!-- Legend -->
  <rect x="30" y={height - 26} width="14" height="8" rx="1" fill="rgba(124,58,237,0.5)" stroke="rgba(124,58,237,0.6)" stroke-width="1"/>
  <text x="50" y={height - 19} font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.45)">lepidlo: rovnoměrná distribuce + tlumení</text>

  <ellipse cx={width - 170} cy={height - 22} rx="5" ry="5" fill="rgba(251,191,36,0.6)"/>
  <text x={width - 160} y={height - 19} font-family="Inter, sans-serif" font-size="10" fill="rgba(255,255,255,0.45)">svár: okamžitá pevnost</text>
</svg>

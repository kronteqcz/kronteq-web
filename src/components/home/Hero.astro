---
import type { Lang } from '../../i18n/strings';
import { getLang } from '../../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'cs' } = Astro.props;
const t = getLang(lang);
---

<section class="hero">
  <!-- Background decoration -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-grid"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-content" data-reveal>
      <p class="hero-tagline">{t.heroTagline}</p>
      <h1 class="hero-title">
        {t.heroTitle.split('\n').map((line: string, i: number) => (
          <>{line}{i < t.heroTitle.split('\n').length - 1 ? <br /> : null}</>
        ))}
      </h1>
      <p class="hero-sub">{t.heroSubtitle}</p>
      <div class="hero-ctas">
        <a href={t.heroCta1Href} class="btn-primary">
          {t.heroCta1}
          <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href={t.heroCta2Href} class="btn-outline">{t.heroCta2}</a>
      </div>
    </div>

    <!-- Visual element -->
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-badge">
        <img src="/assets/logo-full.png" alt="Kronteq" class="badge-logo" />
        <div class="badge-ring badge-ring-1"></div>
        <div class="badge-ring badge-ring-2"></div>
        <div class="badge-ring badge-ring-3"></div>
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="hero-stats">
    <div class="container">
      <div class="stats-row" data-reveal-stagger>
        <div class="stat">
          <span class="stat-number">5+</span>
          <span class="stat-label">{lang === 'en' ? 'Years in adhesives' : 'Let v oboru'}</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-number">6</span>
          <span class="stat-label">{lang === 'en' ? 'Adhesive system categories' : 'Kategorií lepicích systémů'}</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-number">4</span>
          <span class="stat-label">{lang === 'en' ? 'Industries served' : 'Odvětví průmyslu'}</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-number">24h</span>
          <span class="stat-label">{lang === 'en' ? 'Response time' : 'Doba odpovědi'}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--bg-dark);
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-top: 72px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }
  .hero-orb-1 {
    width: 700px; height: 700px;
    top: -150px; right: -200px;
    background: var(--brand);
    opacity: 0.5;
  }
  .hero-orb-2 {
    width: 500px; height: 500px;
    bottom: -50px; left: -150px;
    background: var(--accent);
    opacity: 0.18;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 80%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    padding-block: 5rem;
  }
  @media (min-width: 900px) {
    .hero-inner { grid-template-columns: 1fr 1fr; padding-block: 6rem; }
  }

  .hero-content { position: relative; z-index: 1; }

  .hero-tagline {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-light);
    background: rgba(167,139,250,0.1);
    border: 1px solid rgba(167,139,250,0.2);
    border-radius: 100px;
    padding: 0.35rem 0.875rem;
    margin-bottom: 1.25rem;
    max-width: none;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .hero-sub {
    color: var(--text-dark-muted);
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 52ch;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }
  .hero-badge {
    position: relative;
    width: 320px;
    height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .badge-logo {
    width: 200px;
    height: auto;
    border-radius: 22px;
    z-index: 2;
    box-shadow: 0 0 80px rgba(124,58,237,0.5), 0 0 30px rgba(45,27,85,0.8);
    position: relative;
  }
  .badge-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(167,139,250,0.1);
    animation: spin-slow linear infinite;
  }
  .badge-ring-1 { width: 260px; height: 260px; border-top-color: rgba(167,139,250,0.4); animation-duration: 10s; }
  .badge-ring-2 { width: 300px; height: 300px; border-right-color: rgba(124,58,237,0.25); animation-duration: 18s; animation-direction: reverse; }
  .badge-ring-3 { width: 320px; height: 320px; border-bottom-color: rgba(167,139,250,0.15); animation-duration: 25s; }
  @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .badge-ring { animation: none; } }

  .hero-stats {
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(0,0,0,0.2);
    padding: 1.5rem 0;
  }
  .stats-row {
    display: flex;
    align-items: center;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }
  .stat-number {
    font-family: var(--font-sans);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--accent-light);
    line-height: 1;
  }
  .stat-label { font-size: 0.8125rem; color: var(--text-dark-muted); max-width: none; }
  .stat-divider { width: 1px; height: 36px; background: rgba(255,255,255,0.08); }
  @media (max-width: 640px) {
    .stat-divider { display: none; }
    .stats-row { justify-content: center; gap: 2rem; }
  }
</style>

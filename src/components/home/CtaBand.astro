---
import type { Lang } from '../../i18n/strings';
import { getLang } from '../../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'cs' } = Astro.props;
const t = getLang(lang);
---

<section class="cta-band">
  <div class="cta-bg" aria-hidden="true"></div>
  <div class="container" data-reveal>
    <h2>{t.sectionCta}</h2>
    <p>{t.sectionCtaSub}</p>
    <a href={t.sectionCtaBtnHref} class="btn-primary">
      {t.sectionCtaBtn}
      <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
        <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</section>

<style>
  .cta-band {
    background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand) 40%, #3D1F7A 100%);
    padding-block: 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 120% at 15% 50%, rgba(124,58,237,0.45) 0%, transparent 60%),
      radial-gradient(ellipse 50% 120% at 85% 50%, rgba(167,139,250,0.25) 0%, transparent 60%),
      radial-gradient(ellipse 30% 60% at 50% 0%, rgba(255,255,255,0.04) 0%, transparent 50%);
    pointer-events: none;
  }
  .container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .cta-band h2 {
    color: #fff;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    max-width: none;
  }
  .cta-band p {
    color: rgba(255,255,255,0.7);
    font-size: 1.0625rem;
    max-width: 50ch;
    text-align: center;
  }
</style>

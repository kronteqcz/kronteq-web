---
import type { Lang } from '../../i18n/strings';
import { getLang } from '../../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'cs' } = Astro.props;
const t = getLang(lang);
---

<section class="section why-section">
  <div class="container">
    <div class="section-header" data-reveal>
      <span class="label">{t.sectionWhy}</span>
      <h2>{t.sectionWhy}</h2>
      <p>{t.sectionWhySub}</p>
    </div>

    <div class="why-grid" data-reveal-stagger>
      <div class="why-card">
        <div class="why-number" aria-hidden="true">01</div>
        <div class="icon-box">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
        </div>
        <h3>{t.why1Title}</h3>
        <p>{t.why1Text}</p>
      </div>

      <div class="why-card">
        <div class="why-number" aria-hidden="true">02</div>
        <div class="icon-box">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
        </div>
        <h3>{t.why2Title}</h3>
        <p>{t.why2Text}</p>
      </div>

      <div class="why-card">
        <div class="why-number" aria-hidden="true">03</div>
        <div class="icon-box">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3>{t.why3Title}</h3>
        <p>{t.why3Text}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .why-section {
    background: linear-gradient(180deg, var(--bg-base) 0%, var(--bg-2) 100%);
  }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: 1.5rem;
  }
  .why-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
    overflow: hidden;
  }
  .why-card:hover {
    border-color: var(--border-accent);
    box-shadow: 0 8px 32px rgba(124,58,237,0.08);
  }
  .why-number {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-family: var(--font-sans);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--accent-dim);
    line-height: 1;
  }
  .why-card h3 {
    font-size: 1.15rem;
    margin-top: 0.25rem;
  }
  .why-card p {
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    max-width: none;
  }
</style>

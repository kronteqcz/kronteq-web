---
interface Props {
  lang?: 'cs' | 'en';
}

const { lang = 'cs' } = Astro.props;

const drivers = lang === 'en' ? [
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Lightweight & E-mobility',
    text: 'New vehicle concepts require bonding dissimilar materials — metal, plastic and composites. Essential for electric vehicles and aerospace.',
  },
  {
    icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
    title: 'New materials',
    text: 'The need to join "un-joinable" combinations: metal + plastic, composites + aluminium. Welding cannot cope — adhesive bonding can.',
  },
  {
    icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Ecology & Savings',
    text: 'Lower energy consumption in production versus welding. Supports recyclability. No thermal damage to material surfaces.',
  },
  {
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Efficiency',
    text: 'Faster series production with a lower share of manual work. Automated dispensing systems allow high throughput with consistent quality.',
  },
] : [
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Lehkost & E-mobilita',
    text: 'Nové koncepty vozidel vyžadují spojování různorodých materiálů — kovu, plastu a kompozitů. Nezbytné pro elektromobily a letecký průmysl.',
  },
  {
    icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
    title: 'Nové materiály',
    text: 'Nutnost spojovat "nespojitelné" kombinace: kov + plast, kompozit + hliník. Svařování si neporadí — lepení ano.',
  },
  {
    icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Ekologie & Úspory',
    text: 'Nižší energetická náročnost výroby oproti svařování. Podpora recyklovatelnosti. Žádné tepelné ovlivnění povrchu materiálu.',
  },
  {
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Efektivita',
    text: 'Rychlejší sériová výroba s menším podílem manuální práce. Automatizované dispensingové systémy umožňují vysoký průtok s konzistentní kvalitou.',
  },
];
---

<section class="drivers-section section-dark">
  <div class="container">
    <div class="section-header" data-reveal>
      <span class="label">{lang === 'en' ? 'Why bonding?' : 'Proč lepení?'}</span>
      <h2>{lang === 'en' ? 'Industry is looking for alternatives' : 'Průmysl hledá alternativy'}</h2>
      <p>{lang === 'en'
        ? 'Manufacturing is moving from classic metal structures to lightweight multi-materials. Welding has its limits — adhesive bonding does not.'
        : 'Výrobní průmysl přechází od klasických kovových konstrukcí k lehkým multimateriálům. Svařování má své limity — lepení ne.'
      }</p>
    </div>

    <div class="drivers-grid" data-reveal-stagger>
      {drivers.map(driver => (
        <div class="driver-card card-dark">
          <div class="icon-box-dark">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d={driver.icon} />
            </svg>
          </div>
          <h3>{driver.title}</h3>
          <p>{driver.text}</p>
        </div>
      ))}
    </div>

    <div class="drivers-cta" data-reveal>
      <p class="drivers-cta-note">
        {lang === 'en'
          ? '90% of adhesive bond failures stem from inadequate surface preparation — not from the adhesive itself.'
          : '90 % selhání lepených spojů způsobuje nedostatečná příprava povrchu — ne lepidlo samotné.'
        }
      </p>
    </div>
  </div>
</section>

<style>
  .drivers-section {
    position: relative;
    overflow: hidden;
  }
  .drivers-section::before {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 800px; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(124,58,237,0.4), transparent);
  }

  .drivers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
    gap: 1.25rem;
  }

  .driver-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    position: relative;
    overflow: hidden;
  }
  .driver-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity var(--duration) var(--ease);
  }
  .driver-card:hover::after { opacity: 1; }

  .driver-card h3 {
    font-size: 1.05rem;
    color: #fff;
    margin-top: 0.125rem;
  }
  .driver-card p {
    font-size: 0.9rem;
    color: var(--text-dark-muted);
    line-height: 1.6;
    max-width: none;
  }

  .drivers-cta {
    margin-top: 2.5rem;
    display: flex;
    justify-content: center;
  }
  .drivers-cta-note {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.35);
    text-align: center;
    max-width: 60ch;
    font-style: italic;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 1.5rem;
  }
</style>

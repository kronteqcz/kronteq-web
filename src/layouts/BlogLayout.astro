---
import BaseLayout from './BaseLayout.astro';
import RelatedPosts from '../components/blog/RelatedPosts.astro';
import CategoryBadge from '../components/ui/CategoryBadge.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, category, tags, readingTime } = post.data;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const related = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === category)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);

const formattedDate = pubDate.toLocaleDateString('cs-CZ', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const formattedUpdated = updatedDate?.toLocaleDateString('cs-CZ', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categoryLabel = category === 'ai' ? 'AI' : 'GEO';
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  pubDate={pubDate}
  category={category}
>
  <!-- Schema: Article + BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "datePublished": pubDate.toISOString(),
    ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
    "author": {
      "@type": "Organization",
      "name": "První pozice",
      "url": "https://www.prvni-pozice.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "První pozice",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.prvni-pozice.com/img/1P.svg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": Astro.url.href
    },
    "keywords": tags.join(', ')
  })} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Blog", "item": "https://blog.prvni-pozice.com/" },
      { "@type": "ListItem", "position": 2, "name": categoryLabel, "item": `https://blog.prvni-pozice.com/${category}/` },
      { "@type": "ListItem", "position": 3, "name": title, "item": Astro.url.href }
    ]
  })} slot="head" />

  <!-- Reading progress bar (motion.js ho řídí) -->
  <div class="reading-progress-wrap" aria-hidden="true">
    <div id="readingProgress" class="reading-progress-bar"></div>
  </div>

  <!-- Article Header -->
  <div class="article-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Blog</a>
        <span aria-hidden="true">›</span>
        <a href={`/${category}/`}>{categoryLabel}</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{title}</span>
      </nav>

      <div class="article-header">
        <CategoryBadge category={category} />

        <h1 class="article-title">{title}</h1>
        <p class="article-description">{description}</p>

        <div class="article-meta">
          <time datetime={pubDate.toISOString()} class="meta-date">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            {formattedDate}
          </time>

          {readingTime && (
            <span class="meta-reading">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              {readingTime} min čtení
            </span>
          )}

          {formattedUpdated && (
            <span class="meta-updated">Aktualizováno: {formattedUpdated}</span>
          )}
        </div>
      </div>
    </div>
    <div class="article-hero-glow" aria-hidden="true"></div>
  </div>

  <!-- Article Content -->
  <div class="article-body">
    <div class="container">
      <div class="article-layout">
        <article class="prose">
          <slot />
        </article>

        <!-- Sidebar -->
        <aside class="article-sidebar">
          <div class="sidebar-sticky">
            <div class="sidebar-cta">
              <div class="sidebar-cta-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                  <path d="M2 17l10 5 10-5"></path>
                  <path d="M2 12l10 5 10-5"></path>
                </svg>
              </div>
              <h3>Potřebujete GEO nebo SEO audit?</h3>
              <p>Zjistěte, jak si váš web stojí v AI vyhledávačích.</p>
              <a href="https://www.prvni-pozice.com/cs/14-kontakt/" class="btn-accent" target="_blank" rel="noopener">
                Kontaktujte nás →
              </a>
            </div>

            {tags.length > 0 && (
              <div class="sidebar-tags">
                <h4 class="sidebar-label">Témata</h4>
                <div class="tags-list">
                  {tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            )}

            <div class="sidebar-youtube">
              <h4 class="sidebar-label">YouTube kanál</h4>
              <a
                href="https://www.youtube.com/@prvnipozice"
                class="youtube-link"
                target="_blank"
                rel="noopener"
                aria-label="První pozice YouTube kanál"
              >
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
                <span>@prvnipozice</span>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- Related Posts -->
  {related.length > 0 && (
    <div class="related-section">
      <div class="container">
        <RelatedPosts posts={related} />
      </div>
    </div>
  )}
</BaseLayout>

<style>
  /* ── Reading progress bar ── */
  .reading-progress-wrap {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 2px;
    z-index: 9999;
    background: rgba(255,255,255,0.04);
  }
  .reading-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--accent) 0%, var(--cat-geo) 100%);
    transform: scaleX(0);
    transform-origin: left;
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .reading-progress-wrap { display: none; }
  }

  /* ── Hero ── */
  .article-hero {
    position: relative;
    padding-top: calc(80px + 3rem);
    padding-bottom: 3rem;
    overflow: hidden;
  }

  .article-hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 0%, rgba(174, 211, 1, 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 50%, rgba(1, 211, 174, 0.04) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .article-hero .container {
    position: relative;
    z-index: 1;
  }

  /* ── Breadcrumb ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--duration) var(--ease);
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .breadcrumb span[aria-current] {
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 30ch;
  }

  /* ── Article header ── */
  .article-header {
    max-width: 800px;
  }

  .article-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-top: 1rem;
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .article-description {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 65ch;
    margin-bottom: 1.5rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .meta-date, .meta-reading {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .meta-updated {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  /* ── Article body layout ── */
  .article-body {
    padding-block: 3rem;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr 300px;
      align-items: start;
    }
  }

  /* ── Sidebar ── */
  .sidebar-sticky {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Sidebar entrance animations ── */
  @keyframes sidebarIn {
    from { opacity: 0; transform: translateX(18px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @media (min-width: 1024px) {
    .sidebar-sticky > * {
      animation: sidebarIn 0.45s var(--ease) both;
    }
    .sidebar-sticky > *:nth-child(1) { animation-delay: 0.15s; }
    .sidebar-sticky > *:nth-child(2) { animation-delay: 0.25s; }
    .sidebar-sticky > *:nth-child(3) { animation-delay: 0.35s; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sidebar-sticky > * { animation: none !important; }
  }

  .sidebar-cta {
    background: var(--bg-card);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition:
      border-color 0.25s var(--ease),
      transform    0.25s var(--ease),
      box-shadow   0.25s var(--ease);
  }

  .sidebar-cta:hover {
    border-color: rgba(174, 211, 1, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(174, 211, 1, 0.08);
  }

  .sidebar-cta-icon {
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .sidebar-cta h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .sidebar-cta p {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    max-width: none;
  }

  .btn-accent {
    display: inline-block;
    background: var(--accent);
    color: #08080d;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.6rem 1.25rem;
    border-radius: 100px;
    transition: background var(--duration) var(--ease), transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
    text-decoration: none;
  }

  .btn-accent:hover {
    background: var(--accent-hover);
    color: #08080d;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px var(--accent-glow);
  }

  .sidebar-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 100px;
  }

  .sidebar-tags {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition:
      border-color 0.25s var(--ease),
      transform    0.25s var(--ease),
      box-shadow   0.25s var(--ease);
  }

  .sidebar-tags:hover {
    border-color: rgba(174, 211, 1, 0.25);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(174, 211, 1, 0.06);
  }

  .sidebar-youtube {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition:
      border-color 0.25s var(--ease),
      transform    0.25s var(--ease),
      box-shadow   0.25s var(--ease);
  }

  .sidebar-youtube:hover {
    border-color: rgba(255, 68, 68, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 68, 68, 0.07);
  }

  .youtube-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #ff4444;
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity var(--duration) var(--ease);
    text-decoration: none;
  }

  .youtube-link:hover {
    opacity: 0.8;
    color: #ff4444;
  }

  /* ── Related ── */
  .related-section {
    padding-block: 3rem 5rem;
    border-top: 1px solid var(--border);
  }
</style>

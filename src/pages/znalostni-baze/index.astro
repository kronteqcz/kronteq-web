---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLang } from '../../i18n/strings';

const t = getLang('cs');
const allArticles = await getCollection('kb', ({ data }) => data.lang === 'cs' && !data.draft);
const articles = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryLabels: Record<string, string> = {
  technologie: 'Technologie',
  produkty: 'Produkty',
  automotive: 'Automotive',
  letectvi: 'Letectví',
  elektronika: 'Elektronika',
  stavebnictvi: 'Stavebnictví',
};
---

<BaseLayout
  title="Znalostní báze — technické články o průmyslovém lepení | Kronteq"
  description="Odborné články o průmyslových lepidlech, přípravě povrchu, hybridních spojích a aplikacích v automotive, letectví, elektronice a stavebnictví. Přesná terminologie, konkrétní čísla."
  lang="cs"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Znalostní báze Kronteq",
    "description": "Technické články o průmyslových lepidlech a lepicích technologiích",
    "publisher": { "@type": "Organization", "name": "Kronteq" },
  })} />

  <div class="page-hero section-dark">
    <div class="container">
      <p class="page-label">Kronteq</p>
      <h1>{t.kbTitle}</h1>
      <p class="page-desc">{t.kbDesc}</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="kb-grid" data-reveal-stagger>
        {articles.map(article => (
          <a href={`/znalostni-baze/${article.id.replace(/^cs\//, '')}/`} class="kb-card card">
            <div class="kb-category">
              <span class="category-badge">{categoryLabels[article.data.category] || article.data.category}</span>
            </div>
            <h2 class="kb-title">{article.data.title}</h2>
            <p class="kb-desc">{article.data.description}</p>
            <div class="kb-meta">
              {article.data.readingTimeMinutes && (
                <span class="reading-time">{article.data.readingTimeMinutes} {t.kbReadingTime}</span>
              )}
              <span class="read-more">{t.kbReadMore} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="cta-band section-dark">
    <div class="container cta-band-inner">
      <div>
        <h2>Potřebujete odbornou konzultaci?</h2>
        <p>Teorie je základ. Kristýna Ondráčková vám řekne co přesně použít ve vaší konkrétní aplikaci.</p>
      </div>
      <a href="/kontakt/" class="btn-primary">Konzultace zdarma</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-hero { padding-top: calc(72px + 4rem); padding-bottom: 4rem; }
  .page-label { font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-light); margin-bottom: 1rem; max-width: none; }
  .page-hero h1 { color: #fff; }
  .page-desc { color: var(--text-dark-muted); font-size: 1.125rem; margin-top: 1rem; max-width: 56ch; }

  .kb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 400px), 1fr));
    gap: 1.5rem;
  }

  .kb-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    transition: border-color var(--duration) var(--ease), transform var(--duration) var(--ease);
  }
  .kb-card:hover { border-color: var(--border-accent); transform: translateY(-2px); }

  .category-badge {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(124,58,237,0.1);
    border: 1px solid rgba(124,58,237,0.2);
    border-radius: 100px;
    padding: 0.2rem 0.6rem;
  }

  .kb-title { font-size: 1.0625rem; color: var(--text); line-height: 1.4; }
  .kb-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; max-width: none; flex: 1; }

  .kb-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8125rem;
    margin-top: auto;
  }
  .reading-time { color: var(--text-dim); }
  .read-more { color: var(--accent); font-weight: 500; }

  .cta-band { padding: 4rem 0; }
  .cta-band-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .cta-band h2 { color: #fff; font-size: 1.5rem; margin-bottom: 0.5rem; }
  .cta-band p { color: var(--text-dark-muted); max-width: 50ch; }
  @media (max-width: 768px) { .cta-band-inner { flex-direction: column; align-items: flex-start; } }
</style>

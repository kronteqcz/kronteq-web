---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLang } from '../../i18n/strings';
import { contact } from '../../data/contact';

const t = getLang('cs');
---

<BaseLayout
  title="Kontakt — Kronteq"
  description="Kontaktujte Kronteq. Odpovídáme do 24 hodin. Kristýna Ondráčková, European Adhesive Engineer, Praha 3."
  lang="cs"
>
  <div class="page-hero section-dark">
    <div class="container">
      <p class="page-label">Kronteq</p>
      <h1>{t.contactTitle}</h1>
      <p class="page-desc">{t.contactDesc}</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-layout" data-reveal>
        <!-- Form -->
        <div class="contact-form-wrap">
          <!--
            Napojení formuláře:
            Možnost A — Formspree: zaregistruj se na formspree.io, nahraď action URL:
              action="https://formspree.io/f/XXXXXXXX" method="POST"
            Možnost B — n8n webhook: nastav webhook URL v n8n a použij:
              action="https://your-n8n.domain/webhook/contact" method="POST"
          -->
          <form
            id="contactForm"
            class="contact-form"
            method="POST"
            action="/api/contact"
            novalidate
          >
            <!-- Honeypot — skryté pole; pokud ho bot vyplní, formulář se zahodí -->
            <div class="hp-field" aria-hidden="true">
              <label for="hp_website">Website</label>
              <input type="text" id="hp_website" name="_gotcha" tabindex="-1" autocomplete="off" />
            </div>

            <div class="field">
              <label for="name">{t.contactFormName} <span aria-hidden="true">*</span></label>
              <input type="text" id="name" name="name" required autocomplete="name" placeholder="Jan Novák" />
              <span class="field-error" id="nameError">Vyplňte jméno</span>
            </div>
            <div class="field">
              <label for="company">{t.contactFormCompany}</label>
              <input type="text" id="company" name="company" autocomplete="organization" placeholder="Firma s.r.o." />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="email">{t.contactFormEmail} <span aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" required autocomplete="email" placeholder="jan@firma.cz" />
                <span class="field-error" id="emailError">Zadejte platný e-mail</span>
              </div>
              <div class="field">
                <label for="phone">{t.contactFormPhone}</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="+420 000 000 000" />
              </div>
            </div>
            <div class="field">
              <label for="message">{t.contactFormMessage} <span aria-hidden="true">*</span></label>
              <textarea id="message" name="message" required rows="5" placeholder={t.contactFormMessagePlaceholder}></textarea>
              <span class="field-error" id="messageError">Napište zprávu</span>
            </div>
            <div class="form-footer">
              <p class="form-note">{t.contactFormNote}</p>
              <button type="submit" class="btn-primary" id="submitBtn">
                <span class="btn-label">{t.contactFormSubmit}</span>
                <span class="btn-sending" aria-hidden="true">Odesílám…</span>
              </button>
            </div>
            <div class="form-error-msg" id="formError" role="alert" aria-live="polite"></div>
          </form>
        </div>

        <!-- Info sidebar -->
        <aside class="contact-info">
          <div class="card info-card">
            <h3>{t.contactDirectTitle}</h3>
            <div class="info-person">
              <div class="person-avatar">
                {contact.name.split(' ').map(n => n[0]).join('')}
              </div>
              <div>
                <strong>{contact.name}</strong>
                <span>{contact.titleCs}</span>
              </div>
            </div>
            <ul class="info-list" role="list">
              <li>
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <a href={`tel:${contact.phone.replace(/\s/g, '')}`}>{contact.phone}</a>
              </li>
              <li>
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <a href={`mailto:${contact.email}`}>{contact.email}</a>
              </li>
            </ul>
          </div>

          <div class="card info-card">
            <h3>{t.contactAddressTitle}</h3>
            <address>
              <strong>Kronteq</strong><br />
              {contact.addressLine1}<br />
              {contact.addressLine2}<br />
              {contact.addressLine3}
            </address>
            <a href={contact.mapsUrl} target="_blank" rel="noopener" class="map-link">
              <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Zobrazit na mapě
            </a>
          </div>

          <div class="card info-card response-card">
            <h3>{t.contactResponseTitle}</h3>
            <p class="response-time">{t.contactResponseText}</p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(72px + 4rem);
    padding-bottom: 4rem;
  }
  .page-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1rem;
    max-width: none;
  }
  .page-hero h1 { color: #fff; }
  .page-desc {
    color: var(--text-dark-muted);
    font-size: 1.125rem;
    margin-top: 1rem;
    max-width: 56ch;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 900px) { .contact-layout { grid-template-columns: 1fr 340px; } }

  /* Form */
  .contact-form-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }
  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 640px) { .field-row { grid-template-columns: 1fr; } }

  label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-heading);
  }
  label span { color: var(--accent); }

  input, textarea {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text);
    background: var(--bg-base);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 0.65rem 0.875rem;
    width: 100%;
    transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-dim);
  }
  textarea { resize: vertical; min-height: 120px; }

  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .form-note { font-size: 0.8125rem; color: var(--text-muted); max-width: none; }

  /* Info sidebar */
  .contact-info { display: flex; flex-direction: column; gap: 1rem; }
  .info-card { display: flex; flex-direction: column; gap: 0.875rem; }
  .info-card h3 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .info-person { display: flex; align-items: center; gap: 0.75rem; }
  .person-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--brand);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.8125rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .info-person strong { display: block; font-size: 0.9375rem; color: var(--text-heading); font-weight: 600; }
  .info-person span { font-size: 0.8125rem; color: var(--text-muted); }

  .info-list { list-style: none; display: flex; flex-direction: column; gap: 0.625rem; }
  .info-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
  }
  .info-list svg { stroke: var(--accent); fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
  .info-list a { color: var(--text); text-decoration: none; transition: color var(--duration) var(--ease); }
  .info-list a:hover { color: var(--accent); }

  address {
    font-style: normal;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
  }
  address strong { color: var(--text-heading); }

  .map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
  }
  .map-link:hover { color: var(--accent-hover); }
  .map-link svg { stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }

  .response-time {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
    max-width: none;
  }

  /* Honeypot — absolutně skryté pro člověka, viditeln pro boty */
  .hp-field {
    position: absolute;
    left: -9999px;
    top: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    tab-index: -1;
  }

  /* Validation feedback */
  .field { position: relative; }
  .field-error {
    display: none;
    font-size: 0.8125rem;
    color: #ef4444;
    margin-top: 0.2rem;
  }
  .field.has-error input,
  .field.has-error textarea {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }
  .field.has-error .field-error { display: block; }

  /* Submit button states */
  .btn-sending { display: none; }
  #submitBtn[data-sending] .btn-label { display: none; }
  #submitBtn[data-sending] .btn-sending { display: inline; }
  #submitBtn[data-sending] { opacity: 0.7; pointer-events: none; }

  .form-error-msg {
    font-size: 0.875rem;
    color: #ef4444;
    text-align: center;
    min-height: 1.2em;
  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot check — pokud je vyplněno, tiše zahodit
      const hp = form.querySelector<HTMLInputElement>('[name="_gotcha"]');
      if (hp && hp.value.trim() !== '') {
        window.location.href = '/dekujeme/';
        return;
      }

      // Client-side validation
      let valid = true;
      const fields = [
        { id: 'name', errorId: 'nameError' },
        { id: 'email', errorId: 'emailError' },
        { id: 'message', errorId: 'messageError' },
      ];
      fields.forEach(({ id, errorId }) => {
        const input = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
        const wrap = input?.closest('.field');
        const err = document.getElementById(errorId);
        if (!input || !wrap) return;
        const isEmpty = input.value.trim() === '';
        const isEmailInvalid = id === 'email' && !isEmpty && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value);
        if (isEmpty || isEmailInvalid) {
          wrap.classList.add('has-error');
          valid = false;
        } else {
          wrap.classList.remove('has-error');
        }
      });
      if (!valid) return;

      // Submit
      const btn = document.getElementById('submitBtn') as HTMLButtonElement | null;
      const errMsg = document.getElementById('formError');
      btn?.setAttribute('data-sending', '');

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        const json = await res.json().catch(() => ({}));

        if (res.ok) {
          window.location.href = '/dekujeme/';
        } else {
          throw new Error(json.error ?? `HTTP ${res.status}`);
        }
      } catch (err: unknown) {
        btn?.removeAttribute('data-sending');
        const msg = err instanceof Error ? err.message : 'Odesílání selhalo.';
        if (errMsg) errMsg.textContent = msg + ' Nebo nás kontaktujte přímo e-mailem.';
      }
    });

    // Live validation — odstraní chybu při opravě
    form.querySelectorAll('input, textarea').forEach(el => {
      el.addEventListener('input', () => {
        el.closest('.field')?.classList.remove('has-error');
      });
    });
  }
</script>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLang } from '../../../i18n/strings';
import { services } from '../../../data/services';

const t = getLang('en');
---

<BaseLayout
  title="Services — Adhesive Selection, Surface Preparation, Hybrid Joints | Kronteq"
  description="Technical consulting in bonding technology: adhesive selection, surface preparation, hybrid joint design, validation, supply and training. Certified European Adhesive Engineer."
  lang="en"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Kronteq Services",
    "description": "Technical consulting in bonding technology",
    "itemListElement": services.map((s, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Service",
        "name": s.nameEn,
        "description": s.taglineEn,
        "provider": { "@type": "Organization", "name": "Kronteq" }
      }
    }))
  })} />

  <div class="page-hero section-dark">
    <div class="container">
      <p class="page-label">Kronteq</p>
      <h1>{t.servicesTitle}</h1>
      <p class="page-desc">{t.servicesDesc}</p>
      <a href="/en/contact/" class="btn-primary hero-cta">{t.servicesCta}</a>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="services-list" data-reveal-stagger>
        {services.map((service, idx) => (
          <article class="service-card card" id={service.slug}>
            <div class="service-header">
              <div class="service-num">0{idx + 1}</div>
              <div class="icon-box">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d={service.icon} />
                </svg>
              </div>
              <div class="service-titles">
                <h2 class="service-name">{service.nameEn}</h2>
                <p class="service-tagline">{service.taglineEn}</p>
              </div>
            </div>

            <div class="service-body">
              {service.descEn.split('\n\n').map(para => (
                <p>{para}</p>
              ))}
            </div>

            <div class="service-benefits">
              <h3>{t.servicesBenefitsTitle}</h3>
              <ul role="list">
                {service.benefitsEn.map(b => <li>{b}</li>)}
              </ul>
            </div>

            <a href="/en/contact/" class="btn-outline-dark service-cta">{service.ctaEn}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <div class="cta-band section-dark">
    <div class="container cta-band-inner">
      <div>
        <h2>Not sure what you need?</h2>
        <p>Describe your application — materials, environment, volume — and within 24 hours you'll receive a specific recommendation.</p>
      </div>
      <a href="/en/contact/" class="btn-primary">Free consultation</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-hero { padding-top: calc(72px + 4rem); padding-bottom: 4rem; }
  .page-label { font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-light); margin-bottom: 1rem; max-width: none; }
  .page-hero h1 { color: #fff; }
  .page-desc { color: var(--text-dark-muted); font-size: 1.125rem; margin-top: 1rem; max-width: 56ch; }
  .hero-cta { margin-top: 2rem; }
  .services-list { display: flex; flex-direction: column; gap: 2rem; }
  .service-card { display: flex; flex-direction: column; gap: 1.25rem; }
  .service-header { display: grid; grid-template-columns: auto auto 1fr; align-items: flex-start; gap: 1rem; }
  .service-num { font-size: 1.25rem; font-weight: 800; color: rgba(124,58,237,0.3); line-height: 1; padding-top: 0.2rem; }
  .service-titles { display: flex; flex-direction: column; gap: 0.25rem; }
  .service-name { font-size: 1.375rem; margin: 0; }
  .service-tagline { font-size: 0.9375rem; color: var(--accent); font-style: italic; margin: 0; max-width: none; }
  .service-body p { color: var(--text-muted); font-size: 0.9375rem; line-height: 1.7; max-width: 72ch; }
  .service-body p + p { margin-top: 0.75rem; }
  .service-benefits h3 { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 0.75rem; }
  .service-benefits ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .service-benefits li { font-size: 0.875rem; color: var(--text-muted); padding-left: 1.5rem; position: relative; max-width: none; }
  .service-benefits li::before { content: '✓'; position: absolute; left: 0; color: var(--accent); font-weight: 700; }
  .service-cta { align-self: flex-start; }
  .cta-band { padding: 4rem 0; }
  .cta-band-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .cta-band h2 { color: #fff; font-size: 1.5rem; margin-bottom: 0.5rem; }
  .cta-band p { color: var(--text-dark-muted); max-width: 50ch; }
  @media (max-width: 768px) { .cta-band-inner { flex-direction: column; align-items: flex-start; } .service-header { grid-template-columns: auto 1fr; } .service-num { display: none; } }
</style>

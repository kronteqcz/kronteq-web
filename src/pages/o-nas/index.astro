---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLang } from '../../i18n/strings';
import { contact } from '../../data/contact';

const t = getLang('cs');

const milestones = [
  { year: '2019', text: 'Zahájení spolupráce s předními evropskými výrobci lepicích systémů.' },
  { year: '2021', text: 'Kristýna Ondráčková úspěšně absolvovala certifikaci European Adhesive Engineer (EAE).' },
  { year: '2022', text: 'Rozšíření portfolia o konstrukční lepidla pro automotive a elektroniku.' },
  { year: '2024', text: 'Spuštění technické poradny — bezplatné konzultace pro průmyslové zákazníky po celé Evropě.' },
];

const values = [
  {
    icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
    title: 'Technická přesnost',
    text: 'Každé doporučení je podložené znalostmi chemie polymerů, mechaniky a výrobního procesu. Žádné dohady — jen prověřená fakta.',
  },
  {
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    title: 'Partnerství, ne prodej',
    text: 'Cílem není prodat lepidlo. Cílem je, aby váš spoj fungoval spolehlivě. Proto zůstáváme v kontaktu i po dodávce.',
  },
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Rychlá reakce',
    text: 'Do 24 hodin v pracovní dny. Pro naléhavé aplikace i rychleji. Víme, že výrobní linky nečekají.',
  },
];
---

<BaseLayout
  title="O nás — Kronteq | European Adhesive Engineers"
  description="Kronteq je specializovaný dodavatel průmyslových lepicích systémů. Kristýna Ondráčková, European Adhesive Engineer (EAE) — nejvyšší oborová certifikace v Evropě."
  lang="cs"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "O nás — Kronteq",
    "description": "Kronteq je specializovaný dodavatel průmyslových lepicích systémů",
    "url": "https://www.kronteq.com/o-nas/",
    "publisher": {
      "@type": "Organization",
      "name": "Kronteq",
      "url": "https://www.kronteq.com",
      "employee": {
        "@type": "Person",
        "name": "Kristýna Ondráčková",
        "jobTitle": "European Adhesive Engineer",
        "email": contact.email,
        "telephone": contact.phone
      }
    }
  })} />

  <div class="page-hero section-dark">
    <div class="container">
      <p class="page-label">O nás</p>
      <h1>Lepidla jsou naše věda,<br/>spoje jsou naše řemeslo</h1>
      <p class="page-desc">Specializujeme se výhradně na konstrukční lepení. Žádné divize, žádné kompromisy — jen hloubková znalost lepicích technologií a jejich aplikací v průmyslu.</p>
    </div>
  </div>

  <!-- Main about section -->
  <section class="section">
    <div class="container">
      <div class="about-layout" data-reveal>
        <div class="about-text prose">
          <h2>Kdo jsme</h2>
          <p>Kronteq je česká společnost specializovaná na průmyslová lepidla, tmeliva a lepicí systémy pro náročné průmyslové aplikace. Nejsme generální dodavatel chemie — zaměřujeme se výhradně na konstrukční lepení, kde je hloubková technická znalost nezbytná.</p>

          <p>Naše vedoucí technická specialistka <strong>Kristýna Ondráčková</strong> je držitelkou titulu <strong>European Adhesive Engineer (EAE)</strong> — nejvyšší oborové certifikace pro specialisty na lepicí technologie v Evropě, udělované Evropskou federací asociací pro lepení (EWF). Certifikace pokrývá chemii polymerů, mechaniku lepených spojů, přípravu povrchu, konstrukční výpočty a průmyslové procesy.</p>

          <p>Spolupracujeme přímo s předními světovými výrobci lepicích systémů a přinášíme jejich know-how českým a evropským průmyslovým zákazníkům — s lokální dostupností a osobním přístupem, který velcí hráči nemohou nabídnout.</p>

          <h2>Jak pracujeme</h2>
          <p>Víme, že úspěch lepeného spoje nestojí jen na výběru správného lepidla. <strong>90 % selhání lepených spojů způsobuje nedostatečná příprava povrchu</strong> — nikoli lepidlo samotné. Proto každou konzultaci začínáme analýzou substrátu, podmínek a procesu — a teprve potom vybíráme produkt.</p>

          <p>Zákazníkům nabízíme kompletní servis: technická konzultace a výběr produktu → testování vzorků → dodávka → poprodejní podpora. Pracujeme s odvětvími od automotive a leteckého průmyslu přes elektroniku až po stavebnictví a průmyslovou výrobu.</p>

          <h2>Proč specializace</h2>
          <p>Průmyslová lepidla jsou komplexní technologie. Špatná volba lepidla nebo podcenění přípravy povrchu vede ke drahým reklamacím a výpadkům výroby. Naší hodnotou je přesnost — správný produkt, správný proces, spolehlivý výsledek.</p>
        </div>

        <aside class="about-sidebar">
          <!-- Contact card -->
          <div class="card team-card">
            <h3>Kontaktní osoba</h3>
            <div class="team-member">
              <div class="member-avatar">KO</div>
              <div class="member-info">
                <strong>{contact.name}</strong>
                <span>European Adhesive Engineer</span>
                <span class="member-role">Sales Manager</span>
              </div>
            </div>
            <div class="member-contacts">
              <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="contact-link">
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                {contact.phone}
              </a>
              <a href={`mailto:${contact.email}`} class="contact-link">
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                {contact.email}
              </a>
            </div>
          </div>

          <!-- Key facts -->
          <div class="card facts-card">
            <h3>Klíčová čísla</h3>
            <dl>
              <div><dt>Certifikace</dt><dd>EAE (European Adhesive Engineer)</dd></div>
              <div><dt>Zkušenosti v oboru</dt><dd>5+ let</dd></div>
              <div><dt>Kategorie produktů</dt><dd>9 kategorií</dd></div>
              <div><dt>Odvětví</dt><dd>Automotive, Aerospace, Electronics, Construction</dd></div>
              <div><dt>Pokrytí</dt><dd>Celá Evropa</dd></div>
              <div><dt>Odpověď na poptávku</dt><dd>Do 24 hodin</dd></div>
            </dl>
          </div>

          <!-- CTA -->
          <div class="card cta-card">
            <h3>Máte projekt?</h3>
            <p>Kristýna Ondráčková zhodnotí vaši aplikaci a doporučí nejlepší řešení — zdarma, do 24 hodin.</p>
            <a href="/kontakt/" class="btn-primary" style="margin-top: 0.5rem;">Nezávazná konzultace</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section-dark section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="label">Naše hodnoty</span>
        <h2>Jak přistupujeme ke každé zakázce</h2>
      </div>
      <div class="values-grid" data-reveal-stagger>
        {values.map((v, i) => (
          <div class="value-card card-dark">
            <div class="value-num">0{i + 1}</div>
            <div class="icon-box-dark">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d={v.icon} /></svg>
            </div>
            <h3>{v.title}</h3>
            <p>{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="label">Historie</span>
        <h2>Naše cesta</h2>
      </div>
      <div class="timeline" data-reveal-stagger>
        {milestones.map(m => (
          <div class="timeline-item">
            <div class="timeline-year">{m.year}</div>
            <div class="timeline-dot"></div>
            <div class="timeline-text">{m.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <div class="cta-band section-dark">
    <div class="container">
      <h2>Připraveni pomoci s vaším projektem</h2>
      <p>Ať jde o výběr lepidla, přípravu povrchu nebo validaci procesu — obraťte se na nás.</p>
      <div class="cta-band-btns">
        <a href="/kontakt/" class="btn-primary">Kontaktovat Kristýnu</a>
        <a href="/sluzby/" class="btn-outline">Přehled služeb</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-hero { padding-top: calc(72px + 4rem); padding-bottom: 4rem; }
  .page-label { font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-light); margin-bottom: 1rem; max-width: none; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; }
  .page-desc { color: var(--text-dark-muted); font-size: 1.125rem; margin-top: 1rem; max-width: 60ch; }

  .about-layout { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start; }
  @media (min-width: 900px) { .about-layout { grid-template-columns: 1fr 340px; } }

  .about-text h2 { font-size: 1.375rem; margin: 2rem 0 0.75rem; }
  .about-text p { margin-bottom: 1.1rem; color: var(--text-muted); line-height: 1.75; max-width: 70ch; }
  .about-text strong { color: var(--text-heading); }

  .about-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }

  .team-card { display: flex; flex-direction: column; gap: 1rem; }
  .team-card h3 { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); }
  .team-member { display: flex; align-items: center; gap: 0.875rem; }
  .member-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--brand); color: #fff; font-family: var(--font-sans); font-weight: 700; font-size: 0.875rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .member-info { display: flex; flex-direction: column; gap: 0.1rem; }
  .member-info strong { font-size: 0.9375rem; color: var(--text-heading); font-weight: 600; }
  .member-info span { font-size: 0.8125rem; color: var(--text-muted); }
  .member-role { color: var(--text-dim) !important; font-size: 0.75rem !important; }
  .member-contacts { display: flex; flex-direction: column; gap: 0.5rem; }
  .contact-link { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--accent); text-decoration: none; transition: color var(--duration) var(--ease); }
  .contact-link:hover { color: var(--accent-hover); }
  .contact-link svg { stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }

  .facts-card { display: flex; flex-direction: column; gap: 1rem; }
  .facts-card h3 { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); }
  .facts-card dl { display: flex; flex-direction: column; gap: 0; }
  .facts-card dl > div { display: flex; justify-content: space-between; align-items: baseline; padding: 0.5rem 0; border-bottom: 1px solid var(--border); gap: 0.5rem; }
  .facts-card dt { font-size: 0.8125rem; color: var(--text-muted); flex-shrink: 0; }
  .facts-card dd { font-family: var(--font-sans); font-weight: 600; font-size: 0.875rem; color: var(--text-heading); text-align: right; }

  .cta-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .cta-card h3 { font-size: 1rem; }
  .cta-card p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.55; max-width: none; }

  /* Values */
  .values-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr)); gap: 1.25rem; }
  .value-card { display: flex; flex-direction: column; gap: 0.875rem; padding: 2rem; position: relative; overflow: hidden; }
  .value-num { position: absolute; top: 1.25rem; right: 1.25rem; font-size: 2.5rem; font-weight: 800; color: var(--accent-dim); line-height: 1; }
  .value-card h3 { font-size: 1.05rem; color: #fff; }
  .value-card p { font-size: 0.9rem; color: var(--text-dark-muted); line-height: 1.65; max-width: none; }

  /* Timeline */
  .timeline { display: flex; flex-direction: column; gap: 0; max-width: 680px; }
  .timeline-item { display: grid; grid-template-columns: 64px 24px 1fr; gap: 0 1rem; align-items: start; padding-bottom: 2rem; position: relative; }
  .timeline-item:not(:last-child)::before { content: ''; position: absolute; left: 72px; top: 12px; bottom: 0; width: 1px; background: var(--border); }
  .timeline-year { font-family: var(--font-sans); font-weight: 700; font-size: 0.9rem; color: var(--accent); padding-top: 0.1rem; }
  .timeline-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); margin-top: 0.3rem; flex-shrink: 0; box-shadow: 0 0 0 3px rgba(124,58,237,0.15); }
  .timeline-text { font-size: 0.9375rem; color: var(--text-muted); line-height: 1.65; padding-top: 0; max-width: none; }

  /* CTA band */
  .cta-band { padding: 4rem 0; }
  .cta-band .container { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1rem; }
  .cta-band h2 { color: #fff; font-size: clamp(1.5rem, 3vw, 2rem); }
  .cta-band p { color: var(--text-dark-muted); max-width: 56ch; font-size: 1rem; }
  .cta-band-btns { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-top: 0.5rem; }
</style>

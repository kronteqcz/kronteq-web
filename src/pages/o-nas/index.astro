---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLang } from '../../i18n/strings';
import { contact } from '../../data/contact';

const t = getLang('cs');
---

<BaseLayout
  title="O nás — Kronteq"
  description="Kronteq je česká společnost specializovaná na průmyslová lepidla, tmeliva a aplikační systémy. Tým certifikovaných European Adhesive Engineers."
  lang="cs"
>
  <div class="page-hero section-dark">
    <div class="container">
      <p class="page-label">Kronteq</p>
      <h1>{t.aboutTitle}</h1>
      <p class="page-desc">{t.aboutDesc}</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="about-layout" data-reveal>
        <div class="about-text prose">
          {t.aboutText.split('\n\n').map(para => <p>{para}</p>)}
        </div>

        <aside class="about-sidebar">
          <!-- Team card -->
          <div class="card team-card">
            <h3>{t.aboutTeamTitle}</h3>
            <div class="team-member">
              <div class="member-avatar">
                {contact.name.split(' ').map(n => n[0]).join('')}
              </div>
              <div class="member-info">
                <strong>{contact.name}</strong>
                <span>{contact.titleCs}</span>
              </div>
            </div>
            <div class="member-contacts">
              <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="contact-link">
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                  <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                {contact.phone}
              </a>
              <a href={`mailto:${contact.email}`} class="contact-link">
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                  <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                {contact.email}
              </a>
            </div>
          </div>

          <!-- Key facts -->
          <div class="card facts-card">
            <h3>Klíčová čísla</h3>
            <dl>
              <div>
                <dt>Zkušenosti v oboru</dt>
                <dd>5+ let</dd>
              </div>
              <div>
                <dt>Certifikace</dt>
                <dd>EAE</dd>
              </div>
              <div>
                <dt>Kategorie produktů</dt>
                <dd>6</dd>
              </div>
              <div>
                <dt>Pokrytí</dt>
                <dd>Celá Evropa</dd>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(72px + 4rem);
    padding-bottom: 4rem;
  }
  .page-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1rem;
    max-width: none;
  }
  .page-hero h1 { color: #fff; }
  .page-desc {
    color: var(--text-dark-muted);
    font-size: 1.125rem;
    margin-top: 1rem;
    max-width: 56ch;
  }

  .about-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 900px) {
    .about-layout { grid-template-columns: 1fr 340px; }
  }

  .about-text p { margin-bottom: 1.25rem; max-width: 70ch; }

  .about-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }

  /* Team card */
  .team-card { display: flex; flex-direction: column; gap: 1rem; }
  .team-card h3 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .team-member { display: flex; align-items: center; gap: 0.875rem; }
  .member-avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--brand);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.875rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0.03em;
  }
  .member-info { display: flex; flex-direction: column; gap: 0.125rem; }
  .member-info strong { font-size: 0.9375rem; color: var(--text-heading); font-weight: 600; }
  .member-info span { font-size: 0.8125rem; color: var(--text-muted); }

  .member-contacts { display: flex; flex-direction: column; gap: 0.5rem; }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }
  .contact-link:hover { color: var(--accent-hover); }
  .contact-link svg { stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }

  /* Facts */
  .facts-card { display: flex; flex-direction: column; gap: 1rem; }
  .facts-card h3 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .facts-card dl { display: flex; flex-direction: column; gap: 0.5rem; }
  .facts-card dl > div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
  }
  .facts-card dt { font-size: 0.875rem; color: var(--text-muted); }
  .facts-card dd { font-family: var(--font-sans); font-weight: 700; font-size: 1rem; color: var(--text-heading); }
  .facts-note { font-size: 0.75rem; color: var(--text-dim); font-style: italic; max-width: none; }
</style>
